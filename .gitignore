# ─────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/

# Type checking / linting caches
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# ─────────────────────────────────────────────────────────────
# uv / virtual environments
# ─────────────────────────────────────────────────────────────
.venv/
venv/
ENV/
# NOTE: uv.lock and pyproject.toml ARE committed (reproducibility).
# NOTE: .python-version IS committed (Python version pinning).

# ─────────────────────────────────────────────────────────────
# Django
# ─────────────────────────────────────────────────────────────
*.sqlite3
*.sqlite3-journal
db.sqlite3
local_settings.py
staticfiles/                # generated by `collectstatic`
media/                      # user uploads (env-specific)

# ─────────────────────────────────────────────────────────────
# Secrets / environment
# ─────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
# NOTE: .env.example IS committed (template without real values).
# NOTE: SOPS-encrypted files (e.g. *.enc.yaml) ARE committed —
#       that's the whole point of encrypting them.

# ─────────────────────────────────────────────────────────────
# Node.js (Tailwind, build tools)
# ─────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
.pnpm-debug.log*
# NOTE: package-lock.json IS committed (reproducibility).

# ─────────────────────────────────────────────────────────────
# Docker
# ─────────────────────────────────────────────────────────────
*.tar
docker-compose.override.yml   # local overrides only

# ─────────────────────────────────────────────────────────────
# Terraform
# ─────────────────────────────────────────────────────────────
.terraform/
*.tfstate
*.tfstate.*
*.tfstate.backup
*.tfvars                    # contains values, often sensitive
crash.log
crash.*.log
# NOTE: .terraform.lock.hcl IS committed (provider version locking).
# NOTE: *.tfvars.example CAN be committed as a template.

# ─────────────────────────────────────────────────────────────
# IDE / Editor
# ─────────────────────────────────────────────────────────────
.vscode/
.idea/
.code-workspace
*.swp
*.swo
*~

# ─────────────────────────────────────────────────────────────
# OS
# ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────
*.log
logs/

# ─────────────────────────────────────────────────────────────
# Local notes / scratch
# ─────────────────────────────────────────────────────────────
.scratch/
NOTES.md
TODO.local.md